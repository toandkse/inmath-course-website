<%- include('partials/header', { title: title, user: user, active: active }) %>

<section class="course-detail">
    <div class="detail-card">
        <h2><%= course.title %></h2>
        <div class="detail-meta">
            <span><%= course.tag %></span>
            <span><%= course.type %></span>
            <span><%= course.level %></span>
        </div>
        <p><%= course.details %></p>
        <div class="section-title" style="margin-top:40px; text-align:left;">
            <h3>Nội dung khóa học</h3>
            <p>Khóa học được tổ chức theo từng chương với nội dung rõ ràng giúp bạn ôn luyện hiệu quả.</p>
        </div>
        <ul style="list-style:none; padding-left:0; margin-top:20px;">
            <% course.chapters.forEach((chapter, index) => { %>
                <li style="margin-bottom:18px; padding:22px 24px; background:#f8f9fa; border-radius:18px; border:1px solid #e6e9ef;">
                    <strong><%= chapter.title %></strong>
                    <p style="margin-top:8px; color: var(--text-light);"><%= chapter.description %></p>
                </li>
            <% }) %>
        </ul>
        <div class="card-actions">
            <a href="/">Về trang chủ</a>
            <% if (user) { %>
                <a href="/dashboard">Xem Dashboard</a>
            <% } else { %>
                <a href="/login">Đăng nhập để đăng ký</a>
            <% } %>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
